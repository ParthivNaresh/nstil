{
  "expo": {
    "name": "NStil",
    "slug": "nstil",
    "autolinking": {
      "nativeModulesDir": "./modules"
    },
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "nstil",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nstil.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.nstil.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow NStil to access your photos to attach images to journal entries.",
          "cameraPermission": "Allow NStil to use your camera to take photos for journal entries."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow NStil to access your location to tag journal entries with where you are."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Allow NStil to access your microphone to record voice memos for journal entries."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0A0A0F"
        }
      ]
    ]
  }
}
